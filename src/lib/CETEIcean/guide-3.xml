      <!-- ######################################################### -->
      <!-- (3) EDITORIAL INTERVENTIONS -->
      <!-- ######################################################### -->
      <h1>(3) Editorial Interventions</h1>

      <!-- Editorial supplement -->
      <h2>Editorial supplement</h2>
      <div>
        <p>
          <rs type="person" key="person_9900"
            >Carson McCuller<supplied>s</supplied></rs
          >
        </p>
      </div>

      <!-- Missing or illegible text -->
      <h2>Missing or illegible text</h2>
      <div>
        <p>Lorem ipsum do<gap reason="illegible" quantity="2" /> sit amet...</p>
        <p>Lorem ipsum do<gap reason="lost" quantity="9" /> sit amet...</p>
        <p>Lorem ipsum do<gap reason="damage" quantity="21" /> sit amet...</p>
      </div>

      <!-- Uncertain readings -->
      <h2>Uncertain readings</h2>
      <div>
        <p>Es ist <unclear>an</unclear> sich erschütternd zu denken.</p>
      </div>

      <!-- Choice -->
      <div>
        <h2>Choice: Orig/Reg</h2>
        <!-- A stray uppercase pair caused by a mechanical typewriter slip -->
        <p>
          Era gra<choice><orig>VE</orig><reg>ve</reg></choice
          >mente peggiorata a scuola
        </p>

        <!-- An obvious misspelling -->
        <h2>Choice: Sic/Corr</h2>
        <p>
          <choice><sic>frequantate</sic><corr>frequentate</corr></choice>
        </p>

        <!-- Abbreviations -->
        <h2>Choice: Abbr/Expan</h2>
        <p>
          e ne ricava un certo profitto,
          <choice><abbr>ecc.</abbr><expan>eccetera</expan></choice>
        </p>
      </div>
    </body>
